{
    "name": "calq-dev/laravel-ai-skills",
    "description": "Agent Skills support for the Laravel AI SDK — vendor-agnostic SKILL.md loader with optional Anthropic native container.skills[] integration.",
    "license": "MIT",
    "keywords": [
        "laravel",
        "ai",
        "agent-skills",
        "skills",
        "anthropic",
        "claude"
    ],
    "require": {
        "php": "^8.3",
        "illuminate/console": "^12.0|^13.0",
        "illuminate/contracts": "^12.0|^13.0",
        "illuminate/filesystem": "^12.0|^13.0",
        "illuminate/support": "^12.0|^13.0",
        "laravel/ai": "^0.7",
        "symfony/yaml": "^7.0"
    },
    "require-dev": {
        "laravel/pint": "^1.26",
        "mockery/mockery": "^1.6.12",
        "orchestra/testbench": "^10.6|^11.0",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.0|^12.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "CalqDev\\AiSkills\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "CalqDev\\AiSkills\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "CalqDev\\AiSkills\\AiSkillsServiceProvider"
            ],
            "aliases": {
                "Skills": "CalqDev\\AiSkills\\Facades\\Skills"
            }
        }
    },
    "config": {
        "sort-packages": true
    }
}
